# Backend API base URL (must include /api).
# Leave empty to auto-use:
# - local dev: http://localhost:5000/api
# - remote/devtunnel host: <current-origin>/api
# Example for production: https://api.yourdomain.com/api
VITE_API_URL=

# Optional explicit Socket.io URL (without /api). Usually not needed.
# Leave empty to auto-derive from VITE_API_URL or current origin.
# Example: https://api.yourdomain.com
# VITE_SOCKET_URL=

# Optional: when using a dev tunnel (e.g. devtunnels.ms), set to your frontend tunnel URL to fix 502 / HMR.
# Example: https://b5mqq9wm-5173.inc1.devtunnels.ms
# VITE_DEV_ORIGIN=
