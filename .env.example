# Quiz Platform - example environment file (DO NOT COMMIT SECRETS)

# Node / runtime
NODE_ENV=production
PORT=5000

# Database (MySQL)
DB_HOST=your-db-host
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name

# JWT (used to sign auth tokens) - set to a long, random secret in production
JWT_SECRET=replace_with_a_strong_secret

# CORS (allowed origin for the API)
CORS_ORIGIN=https://your-frontend.example.com

# Master admin (optional - used to bootstrap a single admin)
MASTER_ADMIN_EMAIL=admin@example.com
MASTER_ADMIN_PASSWORD=change_this_password

# Frontend (Vite)
VITE_DEV_ORIGIN=http://localhost:5174

# Optional / integrations
# REDIS_URL=redis://:password@redis-host:6379/0
# SENTRY_DSN=
# DATABASE_URL=mysql://user:pass@host:3306/dbname  # If you prefer a single connection string
